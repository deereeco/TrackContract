rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Legacy path - preserve existing behavior for old share links
    match /users/{userId}/contractions/{contractionId} {
      allow read, write: if true;
    }

    // Named sessions
    match /sessions/{sessionId} {
      // Any authenticated user (Google or anonymous) can read session metadata
      allow read: if request.auth != null;

      // Only a non-anonymous authenticated user can create a session,
      // and they must set themselves as the owner
      allow create: if request.auth != null
                    && request.resource.data.ownerId == request.auth.uid;

      // Only the session owner can update or delete the session document
      allow update, delete: if request.auth != null
                             && resource.data.ownerId == request.auth.uid;

      // Contractions subcollection:
      // Any authenticated user (Google or anonymous with share link) can read and write
      match /contractions/{contractionId} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
